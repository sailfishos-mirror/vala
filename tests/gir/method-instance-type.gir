<?xml version="1.0"?>
<repository version="1.2" xmlns="http://www.gtk.org/introspection/core/1.0" xmlns:c="http://www.gtk.org/introspection/c/1.0" xmlns:glib="http://www.gtk.org/introspection/glib/1.0">
<include name="GObject" version="2.0"/>
<include name="GLib" version="2.0"/>
<include name="Gio" version="2.0"/>
<package name="test"/>
<c:include name="test.h"/>
<namespace name="Test" version="1.0" shared-library="test" c:prefix="Test" c:identifier-prefixes="Test" c:symbol-prefixes="test">
<class name="Foo"
       c:symbol-prefix="foo"
       c:type="TestFoo"
       parent="GLib.Object"
       glib:type-name="TestFoo"
       glib:get-type="test_foo_get_type"
       glib:type-struct="FooClass">
  <field name="parent">
    <type name="GLib.Object" c:type="GObject"/>
  </field>
  <method name="normal" c:identifier="test_foo_normal">
    <return-value transfer-ownership="none">
      <type name="none" c:type="void"/>
    </return-value>
    <parameters>
      <instance-parameter name="self" transfer-ownership="none">
        <type name="Foo" c:type="TestFoo*"/>
      </instance-parameter>
    </parameters>
  </method>
  <method name="bar" c:identifier="test_foo_bar">
    <return-value transfer-ownership="none">
      <type name="none" c:type="void"/>
    </return-value>
    <parameters>
      <instance-parameter name="self" transfer-ownership="none">
        <type name="Bar" c:type="TestBar*"/>
      </instance-parameter>
    </parameters>
  </method>
</class>
<record name="FooClass"
        c:type="TestFooClass"
        glib:is-gtype-struct-for="Foo">
</record>
<class name="Bar"
       c:symbol-prefix="bar"
       c:type="TestBar"
       parent="GLib.Object"
       glib:type-name="TestBar"
       glib:get-type="test_bar_get_type"
       glib:type-struct="BarClass">
  <field name="parent">
    <type name="GLib.Object" c:type="GObject"/>
  </field>
</class>
<record name="BarClass"
        c:type="TestBarClass"
        glib:is-gtype-struct-for="Bar">
</record>
</namespace>
</repository>
